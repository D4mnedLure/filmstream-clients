# Backend endpoints the client talks to. Copy to .env and fill in for local
# builds; .env is gitignored so real endpoints never land in the repo.
# CI injects these from repository secrets (Settings → Secrets and variables →
# Actions): VITE_FILM_BASE, VITE_AUTH_BASE.

VITE_FILM_BASE=https://film.example.com
VITE_AUTH_BASE=https://auth.example.com
