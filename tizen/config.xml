<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets" xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://filmstream.example.com/tv" version="0.1.0" viewmodes="maximized">
    <tizen:application id="FilmStrmTV.FilmStream" package="FilmStrmTV" required_version="2.4"/>
    <content src="index.html"/>
    <feature name="http://tizen.org/feature/screen.size.all"/>
    <icon src="icon.png"/>
    <name>FilmStream</name>
    <tizen:privilege name="http://tizen.org/privilege/internet"/>
    <tizen:profile name="tv"/>
    <!-- WARP: allow the app to reach the backends over the network. -->
    <access origin="*" subdomains="true"/>
    <tizen:allow-navigation>*</tizen:allow-navigation>
    <tizen:setting screen-orientation="landscape" context-menu="disable"
                   background-support="disable" encryption="disable"
                   install-location="auto" hwkey-event="enable"/>
</widget>
